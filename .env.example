# ACE Studio environment variables
# Copy this file to .env.local and adjust as needed

# Backend API URL (required)
# Points to the ACE-Step 1.5 API server
NEXT_PUBLIC_API_URL=http://localhost:8001

# API key (optional, only if your backend requires authentication)
# NEXT_PUBLIC_API_KEY=your-api-key-here

# Safe root directory for file access (used by download API route)
# Defaults to the current user's home directory if not set
# ACESTEP_SAFE_ROOT=/home/youruser
